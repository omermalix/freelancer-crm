{
  "name": "freelancer-crm",
  "description": "Autonomous CRM for managing clients, follow-ups, and invoices.",
  "tools": [
    {
      "name": "crm_action",
      "description": "Perform an action in the freelancer CRM (list clients, check follow-ups, list invoices, generate proposal, or run weekly digest).",
      "parameters": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "enum": ["list", "add", "update", "follow-ups", "invoices", "proposal", "digest"],
            "description": "The CRM action to perform."
          },
          "client_name": { "type": "string", "description": "Client name (required for add/proposal)." },
          "client_status": { "type": "string", "description": "Client status (required for add)." },
          "project_name": { "type": "string", "description": "Project name (required for add/proposal)." },
          "project_cost": { "type": "string", "description": "Project cost (required for add/proposal)." },
          "project_timeline": { "type": "string", "description": "Project timeline (required for proposal)." },
          "phone": { "type": "string", "description": "Client phone number (required for add)." },
          "client_id": { "type": "string", "description": "Client ID (required for update)." },
          "field": { "type": "string", "description": "Field to update (required for update)." },
          "value": { "type": "string", "description": "New value for the field (required for update)." }
        },
        "required": ["action"]
      }
    }
  ]
}
